{
  "name": "raycast-android-daemon",
  "version": "0.1.0",
  "description": "Background daemon for Raycast Android Link — handles device communication",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "bonjour-service": "^1.3.0",
    "node-forge": "^1.3.1",
    "express": "^5.1.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "@types/node-forge": "^1.3.11",
    "@types/express": "^5.0.2",
    "@types/uuid": "^10.0.0",
    "@types/node": "^22.14.0",
    "typescript": "^5.8.2",
    "tsx": "^4.19.0"
  }
}
